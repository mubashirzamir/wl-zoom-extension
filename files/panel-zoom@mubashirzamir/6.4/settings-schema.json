{
    "top-section": {
        "type": "header",
        "description": "Top Panel"
    },
    "top-enabled": {
        "type": "switch",
        "default": true,
        "description": "Enable zoom effect",
        "tooltip": "Apply the hover zoom effect to panels at the top of the screen"
    },
    "top-zoomFactor": {
        "type": "scale",
        "default": 1.3,
        "min": 1.0,
        "max": 2.0,
        "step": 0.1,
        "units": "x",
        "description": "Zoom scale factor",
        "tooltip": "How much applets grow when you hover over the panel",
        "dependency": "top-enabled"
    },

