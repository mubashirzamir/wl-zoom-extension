{
    "zoom-section": {
        "type": "header",
        "description": "Window List Zoom"
    },
    "zoom-enabled": {
        "type": "switch",
        "default": true,
        "description": "Enable zoom effect",
        "tooltip": "Apply a hover zoom effect to window list icons"
    },
    "zoom-zoomFactor": {
        "type": "scale",
        "default": 1.3,
        "min": 1.0,
        "max": 2.0,
        "step": 0.1,
        "units": "x",
        "description": "Zoom scale factor",
        "tooltip": "How much window list icons grow when you hover over them",
        "dependency": "zoom-enabled"
    }
}
